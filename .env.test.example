# E2E Test Environment
# Copy to .env.test and fill in. E2E tests use a SEPARATE database from dev.
# Create a dedicated Turso database for tests: turso db create stratcol-onboard-test

# Required: separate test database (never use your dev/prod DATABASE_URL here)
TEST_DATABASE_URL=
TEST_TURSO_GROUP_AUTH_TOKEN=

# Optional: override test ports (defaults: 3001, 9288)
# PW_WEB_SERVER_PORT=3001
# PW_INNGEST_PORT=9288
# INNGEST_BASE_URL=http://localhost:9288

# Clerk E2E user (same as .env.example)
E2E_CLERK_USER_USERNAME=
E2E_CLERK_USER_PASSWORD=

# Optional: run the slow full-workflow test
# RUN_SLOW_WORKFLOW_TEST=1
